# Voice pipeline (defaults: conversation mode, Whisper final STT, browser TTS)

VITE_VOICE_MODE=conversation
VITE_TURN_SILENCE_MS=1200
VITE_WHISPER_REFINE=true
VITE_MIN_TURN_CHARS=3

# Final STT: whisper | voicebox
VITE_STT_FINAL_PROVIDER=whisper
VITE_WHISPER_BASE=/whisper
VITE_WHISPER_MODEL=whisper-1

# TTS: browser | voicebox
VITE_TTS_PROVIDER=browser
# VITE_TTS_VOICE=Samantha
# VITE_TTS_RATE=1
# VITE_TTS_PITCH=1

# Optional Voicebox LLM fallback (STT/TTS fallback is automatic in app)
VITE_VOICEBOX_ENABLED=false
VITE_VOICEBOX_BASE=/voicebox
VITE_VOICEBOX_PROFILE=Jarvis
