# Copy to .env and replace # remarks with real values. VITE_* = browser (build-time). Others = server-only.

# ── Voice pipeline ───────────────────────────────────────────────────────────

VITE_VOICE_MODE= # conversation | push — mic interaction mode
VITE_TURN_SILENCE_MS= # ms of silence before end-of-turn, e.g. 1200
VITE_WHISPER_REFINE= # true | false — refine browser STT with Whisper
VITE_MIN_TURN_CHARS= # minimum characters to accept a voice turn, e.g. 3

# Final speech-to-text provider
VITE_STT_FINAL_PROVIDER= # whisper | voicebox
VITE_WHISPER_BASE= # Whisper proxy path, e.g. /whisper → localhost:9000
VITE_WHISPER_MODEL= # Whisper model name, e.g. whisper-1

# Text-to-speech provider
VITE_TTS_PROVIDER= # browser | voicebox
VITE_TTS_VOICE= # optional system voice name, e.g. Samantha — browser TTS only
VITE_TTS_RATE= # optional speech rate multiplier, e.g. 1
VITE_TTS_PITCH= # optional speech pitch multiplier, e.g. 1

# Voicebox (optional — enable when docker-compose.voice.yml is running)
VITE_VOICEBOX_ENABLED= # true | false
VITE_VOICEBOX_BASE= # Voicebox proxy path, e.g. /voicebox → localhost:17493
VITE_VOICEBOX_PROFILE= # Voicebox voice profile name, e.g. Jarvis

# ── System Vitals (server-only — never use VITE_ prefix for secrets) ──────────

# YouTube — subscriber count + latest video views
YOUTUBE_API_KEY= # YouTube Data API v3 key from GCP Credentials
YOUTUBE_CHANNEL_ID= # YouTube channel ID from Studio URL, starts with UC

# Instagram — primary path (Meta → Instagram API → API setup with Instagram login)
INSTAGRAM_ACCESS_TOKEN= # Instagram user token from Meta developer dashboard

# Instagram — fallback via linked Facebook Page
FACEBOOK_PAGE_ID= # Facebook Page ID linked to Instagram business account
META_PAGE_ACCESS_TOKEN= # Facebook Page access token with instagram_basic permission

# Ollama — loaded model VRAM for OLLAMA vital slot
OLLAMA_HOST= # Ollama API base URL, e.g. http://127.0.0.1:11434
